# US Data Hub — Environment Variables
# Copy to .env and fill in your values

# Proxy (for Google News, Reddit, Longbridge)
PROXY_URL=http://127.0.0.1:7890

# Database path (default: data/us_data_hub.db)
# DB_PATH=data/us_data_hub.db

# Watchlist (comma-separated, or use config/sources.yaml)
# WATCHLIST=AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA,META

# LLM API (optional, for sentiment analysis)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o-mini

# Longbridge (uses CLI, needs OAuth login first)
# LONGBRIDGE_CLI=longbridge
